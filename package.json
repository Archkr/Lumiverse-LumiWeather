{
  "name": "lumiverse-lumiweather",
  "version": "1.3.3",
  "private": true,
  "type": "module",
  "scripts": {
    "build:backend": "bun build src/backend.ts --outfile dist/backend.js --target bun",
    "build:frontend": "bun scripts/build-frontend.ts",
