{
  "name": "lumiverse-story-weather",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:backend": "bun build src/backend.ts --outfile dist/backend.js --target bun",
    "build:frontend": "bun build src/frontend.ts --outfile dist/frontend.js --target browser",
    "build": "bun run build:backend && bun run build:frontend",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check:dist": "bun scripts/check-dist.ts"
  },
  "devDependencies": {
    "bun-types": "^1.3.12",
    "lumiverse-spindle-types": "0.5.30",
    "typescript": "^5.7.3"
  }
}
